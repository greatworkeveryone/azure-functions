{
  "name": "rpcc-functions",
  "version": "1.0.0",
  "description": "RPCC Azure Functions - myBuildings sync and data API",
  "main": "dist/functions/*.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "func start",
    "build": "tsc && cp src/openapi.json dist/openapi.json",
    "watch": "tsc -w",
    "test": "tsc && node --test dist/__tests__/*.test.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/storage-blob": "^12.31.0",
    "@types/pdfkit": "^0.17.6",
    "pdfkit": "^0.18.0",
    "tedious": "^18.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "azure-functions-core-tools": "^4.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0"
  }
}
